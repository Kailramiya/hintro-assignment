# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Get a free PostgreSQL from https://neon.tech or https://railway.app
DATABASE_URL="postgresql://user:password@host:5432/meeting_intelligence?sslmode=require"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
# Get a free API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ─── Email Notifications (Resend) ─────────────────────────────────────────────
# Get a free API key from https://resend.com (100 emails/day free)
RESEND_API_KEY="your-resend-api-key"
# Must be a verified domain or use Resend's sandbox: onboarding@resend.dev
RESEND_FROM_EMAIL="Meeting Intelligence <notifications@yourdomain.com>"

# ─── App Info (for /api/evaluation endpoint) ─────────────────────────────────
CANDIDATE_NAME="Aman Kundu"
CANDIDATE_EMAIL="amankundu369@gmail.com"
REPOSITORY_URL="https://github.com/yourusername/hintro-meeting-intelligence"
DEPLOYED_URL="https://your-app.railway.app"
